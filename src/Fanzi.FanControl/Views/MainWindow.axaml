<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Fanzi.FanControl.ViewModels"
        xmlns:model="using:Fanzi.FanControl.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="900"
        x:Class="Fanzi.FanControl.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/ionity-logo.ico"
        Title="FANZI — Fan Telemetry &amp; Control | Ionity Global"
        MinWidth="1080"
        MinHeight="760"
        Background="#060E1A">

    <Window.Styles>
        <Style Selector="Border.card">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="Background" Value="#111C2E"/>
            <Setter Property="BorderBrush" Value="#1E3050"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#7A97C2"/>
        </Style>
        <Style Selector="TextBlock.metric-value">
            <Setter Property="FontSize" Value="34"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#F0F4FF"/>
        </Style>
        <Style Selector="TextBlock.metric-caption">
            <Setter Property="Foreground" Value="#6B87AD"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="#1A2E4A"/>
            <Setter Property="Foreground" Value="#C4D8F4"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#254270"/>
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3B82F6"/>
        </Style>
        <Style Selector="Slider">
            <Setter Property="Foreground" Value="#2563EB"/>
        </Style>
    </Window.Styles>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Panel>
        <!-- ═══════════════ LOADER OVERLAY ═══════════════ -->
        <Border IsVisible="{Binding IsLoading}" Background="#060E1A" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="28">
                <Image Source="/Assets/ionity-logo.png" Width="260" Opacity="0.92"/>
                <TextBlock Text="FANZI" FontSize="48" FontWeight="Black" Foreground="#2563EB" HorizontalAlignment="Center"/>
                <TextBlock Text="Initializing hardware sensors..." FontSize="16" Foreground="#6B87AD" HorizontalAlignment="Center"/>
                <ProgressBar IsIndeterminate="True" Width="280" Height="4" Foreground="#2563EB"/>
                <TextBlock Text="Ionity Global (Pty) Ltd" FontSize="13" Foreground="#3A5477" HorizontalAlignment="Center" Margin="0,12,0,0"/>
            </StackPanel>
        </Border>

        <!-- ═══════════════ MAIN CONTENT ═══════════════ -->
        <ScrollViewer IsVisible="{Binding !IsLoading}" VerticalScrollBarVisibility="Auto">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*" Margin="28,20,28,28" RowSpacing="18">

                <!-- ── ROW 0 : HEADER ────────────────────────────── -->
                <Border Grid.Row="0" Classes="card" Padding="26" Background="#0B1525">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="22">
                        <!-- Logo -->
                        <Image Grid.Column="0" Source="/Assets/ionity-logo.png" Width="110" VerticalAlignment="Center" Opacity="0.9"/>

                        <!-- Title block -->
                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="FANZI" FontSize="28" FontWeight="Black" Foreground="#2563EB"/>
                                <TextBlock Text="v1.0" FontSize="14" Foreground="#3A5477" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                            </StackPanel>
                            <TextBlock Text="Fan telemetry, temperature monitoring, and control" FontSize="15" Foreground="#8EACD0"/>
                            <TextBlock Text="Ionity Global (Pty) Ltd  ·  www.ionity.today  ·  ai@ionity.today" FontSize="12" Foreground="#3D5A7A"/>
                        </StackPanel>

                        <!-- Actions -->
                        <StackPanel Grid.Column="2" Spacing="8" VerticalAlignment="Center">
                            <Button Content="↻  Refresh" Classes="primary" Command="{Binding RefreshCommand}" MinWidth="120"/>
                            <Button Content="?  Help" Command="{Binding ToggleHelpCommand}" MinWidth="120"/>
                            <TextBlock Text="{Binding LastUpdated}" HorizontalAlignment="Right" Foreground="#4E6E95" FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── HELP PANEL (toggleable) ───────────────────── -->
                <Border Grid.Row="0" IsVisible="{Binding ShowHelp}" Margin="0,105,0,0" Classes="card" Background="#0D1A2C" ZIndex="50" Padding="24">
                    <StackPanel Spacing="12">
                        <TextBlock Text="FANZI Help" FontSize="22" FontWeight="Bold" Foreground="#F0F4FF"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#8EACD0" FontSize="14" Text="FANZI reads hardware sensors via LibreHardwareMonitor. CPU temperature sensors require administrator privileges (UAC). The app must run as administrator to access ring-0 kernel drivers for temperature data."/>
                        <TextBlock TextWrapping="Wrap" Foreground="#8EACD0" FontSize="14" Text="⚡ FAN channels are standard case/CPU fans. ⭐ PUMP channels are water pump headers (W_PUMP, etc.). ❄ AIO channels are liquid cooler headers. Pumps and AIO devices are typically BIOS-managed and shown separately."/>
                        <TextBlock TextWrapping="Wrap" Foreground="#8EACD0" FontSize="14" Text="Use the slider to set a manual duty percentage, then click Apply. Click Auto to restore BIOS/automatic control. Fan control is only available when the motherboard exposes writable software control endpoints."/>
                        <TextBlock TextWrapping="Wrap" Foreground="#8EACD0" FontSize="14" Text="🎮 RGB LIGHTING: RGB fan control requires vendor-specific software (e.g. Corsair iCUE, ASUS Aura Sync, MSI Mystic Light). FANZI reads hardware telemetry via LibreHardwareMonitor, which does not have access to proprietary RGB LED controllers built into fans or motherboard headers."/>
                        <Separator Background="#1E3050" Height="1" Margin="0,4"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#4E6E95" FontSize="12" Text="Author: Johan Wilhelm van Antwerp  ·  ai@ionity.today  ·  www.ionity.today&#x0a;© 2026 Ionity Global (Pty) Ltd. Powered by LibreHardwareMonitor v0.9.6 and Avalonia UI."/>
                        <Button Content="Close help" Command="{Binding ToggleHelpCommand}" HorizontalAlignment="Right" MinWidth="110"/>
                    </StackPanel>
                </Border>

                <!-- ── STATUS BANNER ─────────────────────────────── -->
                <Border Grid.Row="1" CornerRadius="14" Background="#0C1E34" BorderBrush="#163452" BorderThickness="1" Padding="16,12">
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="#B4CBE8" FontSize="13"/>
                </Border>

                <!-- ── ROW 2 : CPU TEMPERATURES ──────────────────── -->
                <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="16">
                    <Border Grid.Column="0" Classes="card">
                        <StackPanel Spacing="6">
                            <TextBlock Text="CPU PACKAGE" Classes="section-title"/>
                            <TextBlock Text="{Binding CpuPackageTemperature}" Classes="metric-value"/>
                            <TextBlock Text="{Binding CpuName}" Classes="metric-caption" IsVisible="{Binding CpuName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            <TextBlock Text="Primary CPU package sensor" Classes="metric-caption" IsVisible="{Binding CpuName, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Classes="card" Background="#0F1D30">
                        <StackPanel Spacing="6">
                            <TextBlock Text="AVERAGE CORE" Classes="section-title"/>
                            <TextBlock Text="{Binding CpuAverageTemperature}" Classes="metric-value"/>
                            <TextBlock Text="Average across CPU thermal sensors" Classes="metric-caption"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Classes="card" Background="#121828">
                        <StackPanel Spacing="6">
                            <TextBlock Text="HOTSPOT" Classes="section-title"/>
                            <TextBlock Text="{Binding CpuHotspotTemperature}" Classes="metric-value"/>
                            <TextBlock Text="Hottest CPU-related sensor" Classes="metric-caption"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ── ROW 3 : CPU STATS + CPU FAN ───────────────── -->
                <Grid Grid.Row="3" ColumnDefinitions="1.3*,*,*,*,*" ColumnSpacing="16">
                    <!-- CPU Fan Card -->
                    <Border Grid.Column="0" Classes="card" Background="#0D1F35">
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="⚡" FontSize="14"/>
                                <TextBlock Text="{Binding CpuFanName}" Classes="section-title"/>
                            </StackPanel>
                            <TextBlock Text="{Binding CpuFanSpeed}" FontSize="30" FontWeight="Bold" Foreground="#F0F4FF"/>
                            <TextBlock Text="{Binding CpuFanControl}" FontSize="18" FontWeight="SemiBold" Foreground="#2563EB"/>
                            <Slider Minimum="0" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="False" Value="{Binding CpuFanDesiredPercent, Mode=TwoWay}" IsEnabled="{Binding CpuFanCanControl}"/>
                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                <TextBlock Grid.Column="0" Text="{Binding CpuFanDesiredLabel}" Foreground="#6B87AD" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="Apply" Classes="primary" Command="{Binding ApplyCpuFanCommand}" IsEnabled="{Binding CpuFanCanControl}" MinWidth="70"/>
                                <Button Grid.Column="2" Content="Auto" Command="{Binding AutoCpuFanCommand}" IsEnabled="{Binding CpuFanCanControl}" MinWidth="70"/>
                            </Grid>
                            <TextBlock Text="{Binding CpuFanCapability}" Classes="metric-caption" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Classes="card" Background="#0E1C30">
                        <StackPanel Spacing="6">
                            <TextBlock Text="CPU LOAD" Classes="section-title"/>
                            <TextBlock Text="{Binding CpuTotalLoad}" Classes="metric-value"/>
                            <TextBlock Text="Total CPU utilization" Classes="metric-caption"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Classes="card" Background="#10203A">
                        <StackPanel Spacing="6">
                            <TextBlock Text="AVG CLOCK" Classes="section-title"/>
                            <TextBlock Text="{Binding CpuAverageClock}" Classes="metric-value"/>
                            <TextBlock Text="Average core clock" Classes="metric-caption"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Classes="card" Background="#111B2A">
                        <StackPanel Spacing="6">
                            <TextBlock Text="PKG POWER" Classes="section-title"/>
                            <TextBlock Text="{Binding CpuPackagePower}" Classes="metric-value"/>
                            <TextBlock Text="CPU package power" Classes="metric-caption"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" Classes="card" Background="#0F1825">
                        <StackPanel Spacing="6">
                            <TextBlock Text="CORE VOLTAGE" Classes="section-title"/>
                            <TextBlock Text="{Binding CpuCoreVoltage}" Classes="metric-value"/>
                            <TextBlock Text="Vcore voltage" Classes="metric-caption"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ── ROW 4 : GPU METRICS ───────────────────────── -->
                <Grid Grid.Row="4" ColumnDefinitions="*,*,*,*,*" ColumnSpacing="16">
                    <Border Grid.Column="0" Classes="card" Background="#14213A">
                        <StackPanel Spacing="6">
                            <TextBlock Text="GPU CORE TEMP" Classes="section-title"/>
                            <TextBlock Text="{Binding GpuCoreTemperature}" Classes="metric-value"/>
                            <TextBlock Text="{Binding GpuName}" Classes="metric-caption" IsVisible="{Binding GpuName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            <TextBlock Text="Primary GPU thermal" Classes="metric-caption" IsVisible="{Binding GpuName, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Classes="card" Background="#12203D">
                        <StackPanel Spacing="6">
                            <TextBlock Text="GPU HOTSPOT" Classes="section-title"/>
                            <TextBlock Text="{Binding GpuHotspotTemperature}" Classes="metric-value"/>
                            <TextBlock Text="Highest GPU thermal" Classes="metric-caption"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Classes="card" Background="#101E3A">
                        <StackPanel Spacing="6">
                            <TextBlock Text="GPU LOAD" Classes="section-title"/>
                            <TextBlock Text="{Binding GpuLoad}" Classes="metric-value"/>
                            <TextBlock Text="GPU utilization" Classes="metric-caption"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Classes="card" Background="#0E1C36">
                        <StackPanel Spacing="6">
                            <TextBlock Text="GPU CLOCK" Classes="section-title"/>
                            <TextBlock Text="{Binding GpuClock}" Classes="metric-value"/>
                            <TextBlock Text="Core/graphics clock" Classes="metric-caption"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" Classes="card" Background="#0C1A32">
                        <StackPanel Spacing="6">
                            <TextBlock Text="GPU POWER" Classes="section-title"/>
                            <TextBlock Text="{Binding GpuPower}" Classes="metric-value"/>
                            <TextBlock Text="{Binding GpuVram}" Classes="metric-caption" IsVisible="{Binding GpuVram, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            <TextBlock Text="Board or package" Classes="metric-caption" IsVisible="{Binding GpuVram, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ── ROW 5 : WARNINGS & NOTIFICATIONS ──────────── -->
                <Border Grid.Row="5" CornerRadius="14" Background="#150D00" BorderBrush="#5C3A00" BorderThickness="1" Padding="18,14">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="14">
                        <!-- Section header -->
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="⚠" FontSize="18" Foreground="#F59E0B" VerticalAlignment="Center"/>
                            <TextBlock Text="Warnings &amp; Notifications" FontSize="16" FontWeight="Bold" Foreground="#FCD34D" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="24">
                            <!-- Left: temp warning + threshold setting -->
                            <StackPanel Grid.Column="0" Spacing="10">
                                <!-- Active CPU temp warning -->
                                <Border IsVisible="{Binding HasCpuTempWarning}" CornerRadius="10" Background="#1F0D00" BorderBrush="#B45309" BorderThickness="1" Padding="14,10">
                                    <TextBlock Text="{Binding CpuTempWarningMessage}" Foreground="#FDE68A" FontSize="13" TextWrapping="Wrap" FontWeight="SemiBold"/>
                                </Border>
                                <!-- All-clear message when no warning -->
                                <Border IsVisible="{Binding !HasCpuTempWarning}" CornerRadius="10" Background="#071810" BorderBrush="#134E2A" BorderThickness="1" Padding="14,10">
                                    <TextBlock Text="✓  CPU temperature is within normal range." Foreground="#6EE7B7" FontSize="13"/>
                                </Border>
                                <!-- Threshold setting -->
                                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                    <TextBlock Text="Warn when CPU exceeds" Foreground="#8EACD0" FontSize="13" VerticalAlignment="Center"/>
                                    <NumericUpDown Value="{Binding CpuWarningThresholdDegrees, Mode=TwoWay}" Minimum="50" Maximum="110" Increment="5" Width="110" Foreground="#F0F4FF" Background="#0F1E33" FontSize="13" VerticalAlignment="Center" FormatString="0 °C"/>
                                    <TextBlock Text="(default 95 °C)" Foreground="#4E6E95" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Right: email notification -->
                            <Border Grid.Column="1" CornerRadius="12" Background="#0C1A2E" BorderBrush="#1E3050" BorderThickness="1" Padding="16,12" MinWidth="320">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="📧  Report Notifications" FontSize="13" FontWeight="SemiBold" Foreground="#7A97C2"/>
                                    <TextBlock Text="Receive an e-mail alert when temperature thresholds are exceeded." FontSize="12" Foreground="#4E6E95" TextWrapping="Wrap"/>
                                    <TextBox Watermark="Enter e-mail address…" Text="{Binding NotificationEmail, Mode=TwoWay}" FontSize="13" Background="#081320" Foreground="#C4D8F4" BorderBrush="#1E3A60" CornerRadius="8" Padding="10,6"/>
                                    <TextBlock IsVisible="{Binding HasNotificationEmail}" Text="{Binding NotificationEmail, StringFormat='✓  Alerts will be sent to: {0}'}" FontSize="12" Foreground="#34D399" TextWrapping="Wrap"/>
                                    <TextBlock IsVisible="{Binding !HasNotificationEmail}" Text="No e-mail configured — warnings shown in app only." FontSize="12" Foreground="#4E6E95"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- ── ROW 6 : FAN CHANNELS + DETAILED SENSORS ───── -->
                <Grid Grid.Row="6" ColumnDefinitions="2.2*,1.2*" ColumnSpacing="16">
                    <!-- Fan channels list -->
                    <Border Grid.Column="0" Classes="card" Padding="22">
                        <Grid RowDefinitions="Auto,*" RowSpacing="14">
                            <StackPanel>
                                <TextBlock Text="Fan &amp; Pump Channels" FontSize="22" FontWeight="Bold" Foreground="#F0F4FF"/>
                                <TextBlock Text="{Binding FanCountLabel}" Foreground="#6B87AD" FontSize="13"/>
                            </StackPanel>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding FanChannels}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:FanChannelViewModel">
                                            <Border Margin="0,0,0,12" CornerRadius="16" Background="#0A1420" BorderBrush="#1A2C46" BorderThickness="1" Padding="16">
                                                <Grid ColumnDefinitions="2.2*,1.1*,1.7*" ColumnSpacing="16">
                                                    <StackPanel Grid.Column="0" Spacing="6">
                                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                                            <!-- Device kind badge -->
                                                            <Border CornerRadius="8" Background="#1A2E4A" Padding="8,3" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding DeviceKindBadge}" FontSize="11" FontWeight="Bold" Foreground="#5BA3F5"/>
                                                            </Border>
                                                            <TextBlock Text="{Binding Name}" FontSize="20" FontWeight="SemiBold" Foreground="#F0F4FF" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding SourceLabel}" Foreground="#3D5A7A" FontSize="11" IsVisible="{Binding SourceLabel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                        <TextBlock Text="{Binding SpeedLabel}" FontSize="26" FontWeight="Bold" Foreground="#2563EB"/>
                                                        <TextBlock Text="{Binding CapabilityMessage}" TextWrapping="Wrap" Foreground="#5A7899" FontSize="12"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                                        <TextBlock Text="Current" Classes="section-title"/>
                                                        <TextBlock Text="{Binding CurrentControlLabel}" FontSize="22" FontWeight="Bold" Foreground="#F0F4FF"/>
                                                        <TextBlock Text="Target" Classes="section-title" Margin="0,4,0,0"/>
                                                        <TextBlock Text="{Binding DesiredControlLabel}" Foreground="#8EACD0"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2" Spacing="10" VerticalAlignment="Center">
                                                        <Slider Minimum="0" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="False" Value="{Binding DesiredPercent, Mode=TwoWay}" IsEnabled="{Binding CanControl}"/>
                                                        <!-- Low-speed warning (advisory only — not enforced) -->
                                                        <Border IsVisible="{Binding ShowMinSpeedWarning}" CornerRadius="8" Background="#1F1000" BorderBrush="#78350F" BorderThickness="1" Padding="8,5">
                                                            <TextBlock Text="⚠  Below 20% — bearing wear risk. Speed is not enforced." Foreground="#FDE68A" FontSize="11" TextWrapping="Wrap"/>
                                                        </Border>
                                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                                            <TextBlock Grid.Column="0" Text="0%          50%          100%" Foreground="#3D5A7A" FontSize="11" VerticalAlignment="Center"/>
                                                            <Button Grid.Column="1" Content="Apply" Classes="primary" Command="{Binding ApplyCommand}" IsEnabled="{Binding CanControl}" MinWidth="80"/>
                                                            <Button Grid.Column="2" Content="Auto" Command="{Binding AutoCommand}" IsEnabled="{Binding CanControl}" MinWidth="80"/>
                                                        </Grid>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Detailed sensor panels -->
                    <StackPanel Grid.Column="1" Spacing="16">
                        <!-- CPU sensors -->
                        <Border Classes="card" Padding="18" Background="#0B1726" MaxHeight="320">
                            <Grid RowDefinitions="Auto,*" RowSpacing="10">
                                <StackPanel>
                                    <TextBlock Text="CPU Sensors" FontSize="18" FontWeight="Bold" Foreground="#F0F4FF"/>
                                    <TextBlock Text="Temp · Load · Clock · Power · Voltage" Foreground="#4E6E95" FontSize="11"/>
                                </StackPanel>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding CpuReadings}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="model:CpuReadingSnapshot">
                                                <Border Margin="0,0,0,6" CornerRadius="10" Background="#08111E" Padding="10,6">
                                                    <Grid ColumnDefinitions="2.2*,1*">
                                                        <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="#8EACD0" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Value}" Foreground="#2563EB" FontWeight="SemiBold" HorizontalAlignment="Right" FontSize="13"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!-- GPU sensors -->
                        <Border Classes="card" Padding="18" Background="#0B1726" MaxHeight="320">
                            <Grid RowDefinitions="Auto,*" RowSpacing="10">
                                <StackPanel>
                                    <TextBlock Text="GPU Sensors" FontSize="18" FontWeight="Bold" Foreground="#F0F4FF"/>
                                    <TextBlock Text="Temp · Load · Clock · Power · Voltage" Foreground="#4E6E95" FontSize="11"/>
                                </StackPanel>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding GpuReadings}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="model:GpuReadingSnapshot">
                                                <Border Margin="0,0,0,6" CornerRadius="10" Background="#08111E" Padding="10,6">
                                                    <Grid ColumnDefinitions="2.2*,1*">
                                                        <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="#8EACD0" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Value}" Foreground="#2563EB" FontWeight="SemiBold" HorizontalAlignment="Right" FontSize="13"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- ── FOOTER ────────────────────────────────────── -->

            </Grid>
        </ScrollViewer>
    </Panel>

</Window>
